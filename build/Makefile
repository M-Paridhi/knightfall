.PHONY : src/vis_main.s

# target to generate assembly for a file
src/vis_main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\visualizer.dir\build.make CMakeFiles/visualizer.dir/src/vis_main.cpp.s
.PHONY : src/vis_main.cpp.s

tests/perft.obj: tests/perft.cpp.obj
.PHONY : tests/perft.obj

# target to build an object file
tests/perft.cpp.obj:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\perft.dir\build.make CMakeFiles/perft.dir/tests/perft.cpp.obj
.PHONY : tests/perft.cpp.obj

tests/perft.i: tests/perft.cpp.i
.PHONY : tests/perft.i

# target to preprocess a source file
tests/perft.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\perft.dir\build.make CMakeFiles/perft.dir/tests/perft.cpp.i
.PHONY : tests/perft.cpp.i

tests/perft.s: tests/perft.cpp.s
.PHONY : tests/perft.s

# target to generate assembly for a file
tests/perft.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\perft.dir\build.make CMakeFiles/perft.dir/tests/perft.cpp.s
.PHONY : tests/perft.cpp.s

